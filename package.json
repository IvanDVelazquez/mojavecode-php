{
  "name": "mojavecode-php",
  "version": "3.5.1",
  "description": "MojaveCode PHP — A lightweight code editor built with Electron",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:linux": "electron-builder --linux --publish never"
  },
  "author": "MojaveWare",
  "license": "MIT",
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "intelephense": "^1.16.5",
    "material-file-icons": "^2.4.0",
    "monaco-editor": "^0.52.0",
    "node-pty": "^1.0.0",
    "typescript": "^5.9.3",
    "typescript-language-server": "^5.1.3"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.mojaveware.mojavecode-php",
    "productName": "MojaveCode PHP",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "identity": null
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "signingHashAlgorithms": null,
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MojaveCode PHP",
      "uninstallDisplayName": "MojaveCode PHP"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
